generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model categorias {
  id          Int         @id @default(autoincrement())
  nombre      String      @unique @db.VarChar(100)
  descripcion String?
  activo      Boolean     @default(true)
  created_at  DateTime    @default(now()) @db.Timestamp(6)
  productos   productos[]
}

model productos {
  id                     Int                      @id @default(autoincrement())
  codigo_barras          String?                  @unique @db.VarChar(50)
  nombre                 String                   @db.VarChar(200)
  descripcion            String?
  precio_compra          Decimal                  @default(0) @db.Decimal(10, 2)
  precio_venta           Decimal                  @db.Decimal(10, 2)
  stock_actual           Int                      @default(0)
  stock_minimo           Int                      @default(5)
  categoria_id           Int?
  imagen_url             String?                  @db.VarChar(500)
  activo                 Boolean                  @default(true)
  visible_web            Boolean                  @default(true)
  created_at             DateTime                 @default(now()) @db.Timestamp(6)
  updated_at             DateTime                 @default(now()) @db.Timestamp(6)
  detalle_venta          detalle_venta[]
  movimientos_inventario movimientos_inventario[]
  categorias             categorias?              @relation(fields: [categoria_id], references: [id], onUpdate: NoAction)

  @@index([activo], map: "idx_productos_activo")
  @@index([categoria_id], map: "idx_productos_categoria")
  @@index([codigo_barras], map: "idx_productos_codigo")
  @@index([nombre], map: "idx_productos_nombre")
}

model usuarios {
  id                     Int                      @id @default(autoincrement())
  nombre                 String                   @db.VarChar(150)
  email                  String                   @unique @db.VarChar(200)
  password_hash          String                   @db.VarChar(255)
  rol                    String                   @default("cajero") @db.VarChar(20)
  activo                 Boolean                  @default(true)
  created_at             DateTime                 @default(now()) @db.Timestamp(6)
  movimientos_inventario movimientos_inventario[]
  ventas                 ventas[]
}

model ventas {
  id            Int             @id @default(autoincrement())
  folio         String          @unique @db.VarChar(20)
  canal         String          @default("caja") @db.VarChar(10)
  usuario_id    Int?
  subtotal      Decimal         @default(0) @db.Decimal(10, 2)
  descuento     Decimal         @default(0) @db.Decimal(10, 2)
  total         Decimal         @default(0) @db.Decimal(10, 2)
  metodo_pago   String          @default("efectivo") @db.VarChar(20)
  estado        String          @default("completada") @db.VarChar(15)
  notas         String?
  created_at    DateTime        @default(now()) @db.Timestamp(6)
  detalle_venta detalle_venta[]
  usuarios      usuarios?       @relation(fields: [usuario_id], references: [id], onUpdate: NoAction)

  @@index([canal], map: "idx_ventas_canal")
  @@index([created_at], map: "idx_ventas_fecha")
  @@index([folio], map: "idx_ventas_folio")
  @@index([usuario_id], map: "idx_ventas_usuario")
}

model detalle_venta {
  id              Int        @id @default(autoincrement())
  venta_id        Int
  producto_id     Int?
  nombre_producto String     @db.VarChar(200)
  cantidad        Int
  precio_unitario Decimal    @db.Decimal(10, 2)
  subtotal        Decimal    @db.Decimal(10, 2)
  productos       productos? @relation(fields: [producto_id], references: [id], onUpdate: NoAction)
  ventas          ventas     @relation(fields: [venta_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([producto_id], map: "idx_detalle_producto_id")
  @@index([venta_id], map: "idx_detalle_venta_id")
}

model movimientos_inventario {
  id            Int       @id @default(autoincrement())
  producto_id   Int
  usuario_id    Int?
  tipo          String    @db.VarChar(15)
  cantidad      Int
  stock_antes   Int
  stock_despues Int
  motivo        String?
  referencia_id Int?
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  productos     productos @relation(fields: [producto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuarios      usuarios? @relation(fields: [usuario_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_mov_fecha")
  @@index([producto_id], map: "idx_mov_producto")
  @@index([tipo], map: "idx_mov_tipo")
}
