generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id        String        @id @default(cuid()) @db.VarChar(25)
  email     String        @unique @db.VarChar(255)
  password  String        @db.VarChar(255)
  name      String        @db.VarChar(255)
  role      String        @db.VarChar(50)
  active    Boolean?      @default(true)
  createdAt DateTime?     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime?     @default(now()) @updatedAt @db.Timestamptz(6)
  sessions  CashSession[]
  sales     Sale[]
}

model Location {
  id        String        @id @default(cuid()) @db.VarChar(25)
  name      String        @db.VarChar(255)
  type      String        @db.VarChar(50)
  address   String?
  active    Boolean?      @default(true)
  createdAt DateTime?     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime?     @default(now()) @updatedAt @db.Timestamptz(6)
  sessions  CashSession[]
  inventory Inventory[]
  sales     Sale[]
}

model Category {
  id          String    @id @default(cuid()) @db.VarChar(25)
  name        String    @db.VarChar(255)
  description String?
  color       String?   @db.VarChar(20)
  active      Boolean?  @default(true)
  createdAt   DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  products    Product[]
}

model Product {
  id          String      @id @default(cuid()) @db.VarChar(25)
  barcode     String?     @db.VarChar(100)
  name        String      @db.VarChar(255)
  description String?
  imageUrl    String?
  salePrice   Decimal     @db.Decimal(12, 2)
  costPrice   Decimal?    @default(0) @db.Decimal(12, 2)
  unit        String?     @default("pza") @db.VarChar(20)
  categoryId  String?     @db.VarChar(25)
  active      Boolean?    @default(true)
  createdAt   DateTime?   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime?   @default(now()) @updatedAt @db.Timestamptz(6)
  inventory   Inventory[]
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  saleItems   SaleItem[]
}

model Inventory {
  id         String    @id @default(cuid()) @db.VarChar(25)
  productId  String?   @db.VarChar(25)
  locationId String?   @db.VarChar(25)
  quantity   Decimal?  @default(0) @db.Decimal(12, 3)
  minStock   Decimal?  @default(5) @db.Decimal(12, 3)
  createdAt  DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  location   Location? @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product    Product?  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Sale {
  id            String       @id @default(cuid()) @db.VarChar(25)
  invoiceNumber String       @db.VarChar(50)
  locationId    String?      @db.VarChar(25)
  cashierId     String?      @db.VarChar(25)
  sessionId     String?      @db.VarChar(25)
  subtotal      Decimal      @db.Decimal(12, 2)
  tax           Decimal?     @default(0) @db.Decimal(12, 2)
  discount      Decimal?     @default(0) @db.Decimal(12, 2)
  total         Decimal      @db.Decimal(12, 2)
  paymentMethod String?      @default("efectivo") @db.VarChar(20)
  cashReceived  Decimal?     @db.Decimal(12, 2)
  change        Decimal?     @db.Decimal(12, 2)
  status        String?      @default("completada") @db.VarChar(20)
  notes         String?
  createdAt     DateTime?    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime?    @default(now()) @updatedAt @db.Timestamptz(6)
  cashier       User?        @relation(fields: [cashierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location      Location?    @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  session       CashSession? @relation(fields: [sessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items         SaleItem[]
}

model SaleItem {
  id        String    @id @default(cuid()) @db.VarChar(25)
  saleId    String?   @db.VarChar(25)
  productId String?   @db.VarChar(25)
  quantity  Decimal   @db.Decimal(12, 3)
  unitPrice Decimal   @db.Decimal(12, 2)
  costPrice Decimal?  @default(0) @db.Decimal(12, 2)
  discount  Decimal?  @default(0) @db.Decimal(12, 2)
  subtotal  Decimal   @db.Decimal(12, 2)
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sale      Sale?     @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model CashSession {
  id            String    @id @default(cuid()) @db.VarChar(25)
  locationId    String?   @db.VarChar(25)
  cashierId     String?   @db.VarChar(25)
  openingCash   Decimal?  @default(0) @db.Decimal(12, 2)
  openedAt      DateTime  @db.Timestamptz(6)
  closedAt      DateTime? @db.Timestamptz(6)
  status        String?   @default("abierta") @db.VarChar(20)
  totalSales    Decimal?  @default(0) @db.Decimal(12, 2)
  totalCash     Decimal?  @default(0) @db.Decimal(12, 2)
  totalCard     Decimal?  @default(0) @db.Decimal(12, 2)
  totalTransfer Decimal?  @default(0) @db.Decimal(12, 2)
  totalItems    Decimal?  @default(0) @db.Decimal(12, 2)
  closingCash   Decimal?  @db.Decimal(12, 2)
  expectedCash  Decimal?  @db.Decimal(12, 2)
  difference    Decimal?  @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime? @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  cashier       User?     @relation(fields: [cashierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  location      Location? @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales         Sale[]
}
